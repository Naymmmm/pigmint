{
  "name": "pigmint",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "build": "tsc -b && vite build",
    "preview": "wrangler dev",
    "deploy": "pnpm build && wrangler deploy",
    "test": "node --import tsx --test scripts/*.test.ts",
    "typecheck": "tsc -b --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply pigmint --local",
    "db:migrate": "wrangler d1 migrations apply pigmint --remote",
    "cf-typegen": "wrangler types",
    "sync:catalog": "tsx --env-file=.env.local scripts/sync-catalog.ts"
  },
  "dependencies": {
    "@fal-ai/client": "^1.9.5",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@tanstack/react-query": "^5.56.0",
    "@workos-inc/node": "^7.37.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^11.11.0",
    "hono": "^4.6.0",
    "lucide-react": "^0.447.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "stripe": "^17.0.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241004.0",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wrangler": "^4.84.0"
  },
  "packageManager": "pnpm@9.0.0"
}
